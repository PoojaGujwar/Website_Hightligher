{
    "manifest_version":3,
    "name":"Website Highlight Saver",
    "version":"1.0",
    "description":"Save highlighted text from any webpage",
    "permissions":["storage"],

    "action":{
        "default_popup":"popup.html"
    },
    "content_scripts":[
        {
            "matches":["<all_urls>"],
            "js":["content.js"]
        }
    ]
}